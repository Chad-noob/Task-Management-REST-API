{
  "info": {
    "name": "Task Manager API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the Task Management REST API assessment"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Melvin George\",\n  \"email\": \"melvin@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"]}
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"melvin@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {"raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"]}
      }
    },
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Finish backend assessment\",\n  \"description\": \"Complete CRUD routes and documentation\",\n  \"status\": \"pending\"\n}"
        },
        "url": {"raw": "{{base_url}}/api/tasks", "host": ["{{base_url}}"], "path": ["api", "tasks"]}
      }
    },
    {
      "name": "Get All Tasks",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": {
          "raw": "{{base_url}}/api/tasks?page=1&limit=5",
          "host": ["{{base_url}}"],
          "path": ["api", "tasks"],
          "query": [
            {"key": "page", "value": "1"},
            {"key": "limit", "value": "5"}
          ]
        }
      }
    },
    {
      "name": "Update Task Status",
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"completed\"\n}"
        },
        "url": {"raw": "{{base_url}}/api/tasks/1/status", "host": ["{{base_url}}"], "path": ["api", "tasks", "1", "status"]}
      }
    },
    {
      "name": "Delete Task",
      "request": {
        "method": "DELETE",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": {"raw": "{{base_url}}/api/tasks/1", "host": ["{{base_url}}"], "path": ["api", "tasks", "1"]}
      }
    }
  ],
  "variable": [
    {"key": "base_url", "value": "http://localhost:8000"},
    {"key": "token", "value": ""}
  ]
}
